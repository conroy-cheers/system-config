diff --git a/src/modules/apps.ts b/src/modules/apps.ts
index b81d65b..d10f357 100644
--- a/src/modules/apps.ts
+++ b/src/modules/apps.ts
@@ -27,15 +27,23 @@ export function getAstalApps(): AstalApps.Apps {
 
 /** execute apps and commands using Hyprland's exec dispatcher.
     supports desktop entries and usage of uwsm if it's active */
 export function execApp(app: AstalApps.Application|string, dispatchExecArgs?: string) {
+    // Preserve desktop-entry launch semantics for discovered applications so
+    // Terminal=true, D-Bus activation, startup notification, and field-code
+    // expansion all work correctly.
+    if(typeof app !== "string" && dispatchExecArgs === undefined) {
+        app.launch();
+        return;
+    }
+
     const executable = (typeof app === "string") ? app 
         : app.executable.replace(/%[fFcuUik]/g, "");
 
     AstalHyprland.get_default().dispatch("exec", 
         `${dispatchExecArgs ? `${dispatchExecArgs} ` : ""}${
             uwsmIsActive ? "uwsm-app -- " : executable.endsWith(".desktop") ?
                 "gtk-launch "
             : ""
         }${executable}`
     );
 }
