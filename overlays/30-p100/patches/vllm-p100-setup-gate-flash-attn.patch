@@ -824,6 +824,33 @@ def _is_cuda() -> bool:
     return VLLM_TARGET_DEVICE == "cuda" and has_cuda and not _is_tpu()
 
 
+def _get_requested_cuda_arches() -> list[tuple[int, int]]:
+    arches: list[tuple[int, int]] = []
+    for env_name in (
+        "TORCH_CUDA_ARCH_LIST",
+        "CMAKE_CUDA_ARCHITECTURES",
+        "CUDAARCHS",
+    ):
+        for raw_arch in os.getenv(env_name, "").replace(",", ";").split(";"):
+            arch = raw_arch.strip().removesuffix("+PTX")
+            if not arch:
+                continue
+            if "." in arch:
+                major, minor = arch.split(".", 1)
+            elif len(arch) >= 2 and arch.isdigit():
+                major, minor = arch[:-1], arch[-1]
+            else:
+                continue
+            if major.isdigit() and minor.isdigit():
+                arches.append((int(major), int(minor)))
+    return arches
+
+
+def _has_requested_cuda_arch_at_least(major: int, minor: int) -> bool:
+    arches = _get_requested_cuda_arches()
+    return not arches or any(arch >= (major, minor) for arch in arches)
+
