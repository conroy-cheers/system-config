+template <typename scalar_t>
+__device__ __forceinline__ void atomic_add_scalar(scalar_t* address,
+                                                  scalar_t value) {
+  atomicAdd(address, value);
+}
+
+template <>
+__device__ __forceinline__ void atomic_add_scalar<half>(half* address,
+                                                        half value) {
+#if defined(__CUDA_ARCH__) && __CUDA_ARCH__ < 700
+  auto* base = reinterpret_cast<unsigned int*>(
+      reinterpret_cast<uintptr_t>(address) & ~uintptr_t{0x3});
+  const bool high_half = (reinterpret_cast<uintptr_t>(address) & 0x2) != 0;
+
+  unsigned int old = *base;
+  unsigned int assumed;
+  do {
+    assumed = old;
+    const unsigned short old_bits =
+        high_half ? static_cast<unsigned short>(assumed >> 16)
+                  : static_cast<unsigned short>(assumed & 0xffff);
+    const half old_value = __ushort_as_half(old_bits);
+    const half new_value = __hadd(old_value, value);
+    const unsigned int new_bits = __half_as_ushort(new_value);
+    const unsigned int desired =
+        high_half ? ((assumed & 0x0000ffff) | (new_bits << 16))
+                  : ((assumed & 0xffff0000) | new_bits);
+    old = atomicCAS(base, assumed, desired);
+  } while (old != assumed);
+#else
+  atomicAdd(address, value);
+#endif
+}
