+                            yield base.replace(
+                                f"gate_up_proj_{suffix}",
+                                f"up_proj.{suffix_map[suffix]}",
+                            ), up_weight
+                        continue
+
+                if "moe.down_proj_" in name and weight.dim() == 3:
+                    suffix = name.rsplit("down_proj_", 1)[1]
+                    suffix_map = {
+                        "packed": "weight_packed",
+                        "scale": "weight_scale",
+                    }
+                    if suffix in suffix_map:
+                        num_experts = weight.size(0)
+                        for expert_id in range(num_experts):
